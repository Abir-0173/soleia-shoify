{% comment %}
  Soleia — About Hero Section with Liquid Effect INSIDE the section
  File: sections/soleia-about-hero.liquid
{% endcomment %}

{{ 'section-soleia-about-hero.css' | asset_url | stylesheet_tag }}

<section class="s-about-hero" id="s-about-hero-{{ section.id }}">

  {%- comment -%}
    STEP 1 — Background image sits at z-index 0 (bottom layer)
  {%- endcomment -%}
  <div class="s-about-hero__bg">
    {%- if section.settings.background_image != blank -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 2000 }}"
        srcset="
          {{ section.settings.background_image | image_url: width: 600 }} 600w,
          {{ section.settings.background_image | image_url: width: 1000 }} 1000w,
          {{ section.settings.background_image | image_url: width: 1400 }} 1400w,
          {{ section.settings.background_image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ section.settings.background_image.alt | escape | default: 'About Soleia' }}"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 's-about-hero__placeholder' }}
    {%- endif -%}
  </div>

  {%- comment -%}
    STEP 2 — Liquid canvas at z-index 2, INSIDE the section.
    The bg image URL is passed as data-bg-image so the liquid
    shader uses your actual photo as its texture.
    NO {% render %} call needed — the canvas is right here.
  {%- endcomment -%}
  <canvas
    class="s-about-hero__liquid"
    id="s-about-liquid-{{ section.id }}"
    aria-hidden="true"
    {%- if section.settings.background_image != blank -%}
      data-bg-image="{{ section.settings.background_image | image_url: width: 1800 }}"
    {%- endif -%}
  ></canvas>

  {%- comment -%}
    STEP 3 — Nav + content at z-index 10 (top layer, always clickable)
  {%- endcomment -%}
  <header class="s-about-hero__nav">
    <nav class="s-about-hero__nav-inner" role="navigation" aria-label="Main navigation">
      <a
        href="{{ section.settings.nav_left_url | default: routes.root_url }}"
        class="s-about-hero__nav-link s-about-hero__nav-link--left"
      >
        {{ section.settings.nav_left | default: 'About' }}
      </a>

      <a href="{{ routes.root_url }}" class="s-about-hero__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 240 }}"
            alt="{{ shop.name | escape }}"
            width="{{ section.settings.logo.width }}"
            height="{{ section.settings.logo.height }}"
            loading="eager"
          >
        {%- else -%}
          <span class="s-about-hero__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        {%- endif -%}
      </a>

      <a
        href="{{ section.settings.nav_right_url | default: routes.root_url }}"
        class="s-about-hero__nav-link s-about-hero__nav-link--right"
      >
        {{ section.settings.nav_right | default: 'Contact' }}
      </a>
    </nav>
  </header>

  <div class="s-about-hero__content">
    {%- if section.settings.label != blank -%}
      <p class="s-about-hero__label">{{ section.settings.label }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="s-about-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
  </div>

</section>

{%- comment -%} Liquid effect script — same library as soleia-liquid-hero {%- endcomment -%}
<script type="module">
(function () {
  var sectionEl = document.getElementById('s-about-hero-{{ section.id }}');
  var canvas    = document.getElementById('s-about-liquid-{{ section.id }}');
  if (!canvas || !sectionEl) return;

  var bgImage = canvas.dataset.bgImage || '';

  function buildFallback(W, H) {
    var tc  = document.createElement('canvas');
    var dpr = Math.min(devicePixelRatio, 2);
    tc.width  = W * dpr;
    tc.height = H * dpr;
    var ctx = tc.getContext('2d');
    ctx.scale(dpr, dpr);
    ctx.fillStyle = '#0f0c08';
    ctx.fillRect(0, 0, W, H);
    var grd = ctx.createRadialGradient(W * .55, H * .38, 0, W * .55, H * .38, W * .72);
    grd.addColorStop(0,   'rgba(160,100,50,.50)');
    grd.addColorStop(.45, 'rgba(80,40,10,.28)');
    grd.addColorStop(1,   'rgba(0,0,0,0)');
    ctx.fillStyle = grd;
    ctx.fillRect(0, 0, W, H);
    var leg = ctx.createLinearGradient(0, H * .45, 0, H);
    leg.addColorStop(0, 'rgba(0,0,0,0)');
    leg.addColorStop(1, 'rgba(0,0,0,.55)');
    ctx.fillStyle = leg;
    ctx.fillRect(0, 0, W, H);
    return tc.toDataURL('image/webp', 0.9);
  }

  import('https://cdn.jsdelivr.net/npm/threejs-components@0.0.27/build/backgrounds/liquid1.min.js')
    .then(function (mod) {
      var LiquidBackground = mod.default;

      var W = sectionEl.offsetWidth;
      var H = sectionEl.offsetHeight;
      canvas.width  = W;
      canvas.height = H;

      var app = LiquidBackground(canvas);

      /* Use actual bg image as texture so IT gets distorted */
      app.loadImage(bgImage || buildFallback(W, H));
      app.liquidPlane.material.metalness = 0.80;
      app.liquidPlane.material.roughness = 0.20;
      app.liquidPlane.uniforms.displacementScale.value = 5;
      app.setRain(false);

      new ResizeObserver(function () {
        canvas.width  = sectionEl.offsetWidth;
        canvas.height = sectionEl.offsetHeight;
        if (!bgImage) app.loadImage(buildFallback(sectionEl.offsetWidth, sectionEl.offsetHeight));
      }).observe(sectionEl);

      var mq = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (mq.matches) app.liquidPlane.uniforms.displacementScale.value = 0;
    })
    .catch(function (err) {
      console.warn('[Soleia About Liquid]', err);
      canvas.style.display = 'none';
    });
})();
</script>

{% schema %}
{
  "name": "Soleia About Hero",
  "tag": "section",
  "class": "soleia-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "This image is used as the liquid texture — it gets distorted by the effect."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image (overrides text logo)"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "soleia"
    },
    {
      "type": "text",
      "id": "nav_left",
      "label": "Left Nav Label",
      "default": "About"
    },
    {
      "type": "url",
      "id": "nav_left_url",
      "label": "Left Nav URL"
    },
    {
      "type": "text",
      "id": "nav_right",
      "label": "Right Nav Label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "nav_right_url",
      "label": "Right Nav URL"
    },
    {
      "type": "header",
      "content": "Page Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Small Label (above heading)",
      "default": "About Soleia"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Large Heading",
      "default": "A flavour-first functional tea, combining pure taste with targeted botanicals in a plastic-free, dissolvable format."
    }
  ],
  "presets": [
    {
      "name": "Soleia About Hero"
    }
  ]
}
{% endschema %}
