{% comment %}
  Soleia Hero Section — Liquid Distortion Version
  File: sections/soleia-hero.liquid
{% endcomment %}

{{ 'section-soleia-hero.css' | asset_url | stylesheet_tag }}

<style>
@font-face {
  font-family: "CooperLtBTW08-Regular";
  src:
    url('{{ "CooperLtBTW08-Regular.woff2" | asset_url }}') format("woff2"),
    url('{{ "CooperLtBTW08-Regular.woff" | asset_url }}') format("woff");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: "Larsseit";
  src:
    url('{{ "Larsseit-ExtraLight.woff2" | asset_url }}') format("woff2"),
    url('{{ "Larsseit-ExtraLight.woff" | asset_url }}') format("woff");
  font-weight: 200;
  font-style: normal;
  font-display: swap;
}
</style>

<section class="soleia-hero" id="soleia-hero-{{ section.id }}">

  <div class="soleia-hero__bg">

    {% if section.settings.hero_image != blank %}
      <img
        class="soleia-hero__bg-image"
        src="{{ section.settings.hero_image | image_url: width: 2000 }}"
        srcset="
          {{ section.settings.hero_image | image_url: width: 600 }} 600w,
          {{ section.settings.hero_image | image_url: width: 1000 }} 1000w,
          {{ section.settings.hero_image | image_url: width: 1400 }} 1400w,
          {{ section.settings.hero_image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        width="{{ section.settings.hero_image.width }}"
        height="{{ section.settings.hero_image.height }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'soleia-hero__placeholder' }}
    {% endif %}

  </div>

  <canvas
    class="soleia-hero__liquid"
    id="soleia-liquid-{{ section.id }}"
    aria-hidden="true"
    {% if section.settings.hero_image != blank %}
      data-bg-image="{{ section.settings.hero_image | image_url: width: 1800 }}"
    {% endif %}
  ></canvas>

  <div class="soleia-hero__overlay"></div>

  <header class="soleia-hero__nav">
    <nav class="soleia-hero__nav-inner" role="navigation" aria-label="Hero navigation">

      <a
        href="{{ section.settings.nav_left_url | default: routes.root_url }}"
        class="soleia-hero__nav-link soleia-hero__nav-link--left"
      >
        {{ section.settings.nav_left | default: 'About' | upcase }}
      </a>

      <a href="{{ routes.root_url }}" class="soleia-hero__logo" aria-label="{{ shop.name }}">

        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url: width: 240 }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo.width }}"
            height="{{ section.settings.logo.height }}"
            loading="eager"
          >
        {% else %}
          <span class="soleia-hero__logo-text">
            {{ section.settings.logo_text | default: shop.name }}
          </span>
        {% endif %}

      </a>

      <a
        href="{{ section.settings.nav_right_url | default: routes.root_url }}"
        class="soleia-hero__nav-link soleia-hero__nav-link--right"
      >
        {{ section.settings.nav_right | default: 'Contact' | upcase }}
      </a>

    </nav>
  </header>

  <div class="soleia-hero__content">

    <div class="soleia-hero__content-inner">

      <div class="soleia-hero__text">

        {% if section.settings.heading != blank %}
          <h1 class="soleia-hero__heading">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="soleia-hero__subheading">
            {{ section.settings.subheading }}
          </p>
        {% endif %}

        {% if section.settings.cta_label != blank %}
          <a
            href="{{ section.settings.cta_url | default: '#waitlist' }}"
            class="soleia-hero__cta"
          >
            {{ section.settings.cta_label | upcase }}
          </a>
        {% endif %}

      </div>

      {% if section.settings.instagram_url != blank %}
        <a
          href="{{ section.settings.instagram_url }}"
          class="soleia-hero__social"
          aria-label="Follow us on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      {% endif %}

    </div>

  </div>

</section>

<script type="module">
(() => {

  const sectionEl = document.getElementById('soleia-hero-{{ section.id }}');
  const canvas = document.getElementById('soleia-liquid-{{ section.id }}');

  if (!sectionEl || !canvas) return;

  const bgImage = canvas.dataset.bgImage || '';

  function resizeCanvas() {
    canvas.width = sectionEl.offsetWidth;
    canvas.height = sectionEl.offsetHeight;
  }

  resizeCanvas();

  function buildFallback(W, H) {

    const tc = document.createElement('canvas');
    const dpr = Math.min(devicePixelRatio, 2);

    tc.width = W * dpr;
    tc.height = H * dpr;

    const ctx = tc.getContext('2d');

    ctx.scale(dpr, dpr);

    ctx.fillStyle = '#120d09';
    ctx.fillRect(0, 0, W, H);

    const grd = ctx.createRadialGradient(
      W * 0.5,
      H * 0.35,
      0,
      W * 0.5,
      H * 0.35,
      W * 0.7
    );

    grd.addColorStop(0, 'rgba(170,120,70,.50)');
    grd.addColorStop(.45, 'rgba(90,40,10,.30)');
    grd.addColorStop(1, 'rgba(0,0,0,0)');

    ctx.fillStyle = grd;
    ctx.fillRect(0, 0, W, H);

    return tc.toDataURL('image/webp', 0.92);
  }

  import('https://cdn.jsdelivr.net/npm/threejs-components@0.0.27/build/backgrounds/liquid1.min.js')
    .then((mod) => {

      const LiquidBackground = mod.default;

      const app = LiquidBackground(canvas);

      app.loadImage(
        bgImage || buildFallback(
          sectionEl.offsetWidth,
          sectionEl.offsetHeight
        )
      );

      app.liquidPlane.material.metalness = 0.8;
      app.liquidPlane.material.roughness = 0.2;

      app.liquidPlane.uniforms.displacementScale.value = 5;

      app.setRain(false);

      const resizeObserver = new ResizeObserver(() => {
        resizeCanvas();
      });

      resizeObserver.observe(sectionEl);

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      if (reducedMotion.matches) {
        app.liquidPlane.uniforms.displacementScale.value = 0;
      }

    })
    .catch((err) => {
      console.warn('[SOLEIA HERO LIQUID]', err);
      canvas.style.display = 'none';
    });

})();
</script>

{% schema %}
{
  "name": "Soleia Hero",
  "tag": "section",
  "class": "soleia-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "soleia"
    },
    {
      "type": "text",
      "id": "nav_left",
      "label": "Left Nav Label",
      "default": "About"
    },
    {
      "type": "url",
      "id": "nav_left_url",
      "label": "Left Nav URL"
    },
    {
      "type": "text",
      "id": "nav_right",
      "label": "Right Nav Label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "nav_right_url",
      "label": "Right Nav URL"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "A new format for modern tea"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Plastic-free tea strips that dissolve in seconds."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Join Waitlist"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    }
  ],
  "presets": [
    {
      "name": "Soleia Hero"
    }
  ]
}
{% endschema %}