{% comment %}
  Soleia Hero Section — Shopify Liquid
  Section: Hero with full-bleed background VIDEO, nav, headline, CTA
  Mobile-first, responsive
{% endcomment %}

{{ 'section-soleia-hero.css' | asset_url | stylesheet_tag }}

<section class="soleia-hero" id="soleia-hero-{{ section.id }}">
  {%- comment -%} Background Video {%- endcomment -%}
  <div class="soleia-hero__bg">
    {%- if section.settings.video_shopify != blank or section.settings.video_url_mp4 != blank -%}
      <video
        class="soleia-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-hidden="true"
        {%- if section.settings.video_poster != blank -%}
          poster="{{ section.settings.video_poster | image_url: width: 1800 }}"
        {%- endif -%}
      >
        {%- if section.settings.video_shopify != blank -%}
          {%- assign hosted_video = section.settings.video_shopify -%}
          {%- for source in hosted_video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        {%- elsif section.settings.video_url_mp4 != blank -%}
          <source src="{{ section.settings.video_url_mp4 }}" type="video/mp4">
        {%- endif -%}

        {%- comment -%} Image fallback inside <video> for no-JS / unsupported browsers {%- endcomment -%}
        {%- if section.settings.video_poster != blank -%}
          <img
            src="{{ section.settings.video_poster | image_url: width: 1800 }}"
            width="{{ section.settings.video_poster.width }}"
            height="{{ section.settings.video_poster.height }}"
            alt="Hero background"
          >
        {%- endif -%}
      </video>

    {%- elsif section.settings.video_poster != blank -%}
      {%- comment -%} No video — show poster image only {%- endcomment -%}
      <img
        class="soleia-hero__video-fallback"
        src="{{ section.settings.video_poster | image_url: width: 1800 }}"
        srcset="
          {{ section.settings.video_poster | image_url: width: 600 }} 600w,
          {{ section.settings.video_poster | image_url: width: 1200 }} 1200w,
          {{ section.settings.video_poster | image_url: width: 1800 }} 1800w
        "
        sizes="100vw"
        width="{{ section.settings.video_poster.width }}"
        height="{{ section.settings.video_poster.height }}"
        alt="{{ section.settings.video_poster.alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'soleia-hero__placeholder' }}
    {%- endif -%}

    <div class="soleia-hero__overlay"></div>
  </div>

  {%- comment -%} Navigation {%- endcomment -%}
  <header class="soleia-hero__nav">
    <nav class="soleia-hero__nav-inner" role="navigation" aria-label="Hero navigation">
      <a
        href="{{ section.settings.nav_left_url | default: routes.root_url }}"
        class="soleia-hero__nav-link soleia-hero__nav-link--left"
      >
        {{ section.settings.nav_left | default: 'About' | upcase }}
      </a>

      <a href="{{ routes.root_url }}" class="soleia-hero__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 240 }}"
            alt="{{ shop.name }}"
            width="120"
            height=""
            loading="eager"
          >
        {%- else -%}
          <span class="soleia-hero__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        {%- endif -%}
      </a>

      <a
        href="{{ section.settings.nav_right_url | default: routes.root_url | append: 'pages/contact' }}"
        class="soleia-hero__nav-link soleia-hero__nav-link--right"
      >
        {{ section.settings.nav_right | default: 'Contact' | upcase }}
      </a>
    </nav>
  </header>

  {%- comment -%} Hero Content {%- endcomment -%}
  <div class="soleia-hero__content">
    <div class="soleia-hero__content-inner">
      <div class="soleia-hero__text">
        {%- if section.settings.heading != blank -%}
          <h1 class="soleia-hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="soleia-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_url | default: '#waitlist' }}"
          class="soleia-hero__cta"
        >
          {{ section.settings.cta_label | upcase }}
        </a>
      {%- endif -%}
      </div>
      {%- if section.settings.instagram_url != blank -%}
        <a
          href="{{ section.settings.instagram_url }}"
          class="soleia-hero__social"
          aria-label="Follow us on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
    {%- comment -%} Instagram Icon — Bottom Right {%- endcomment -%}
  </div>

</section>

{%- comment -%}
  Pause video for users who prefer reduced motion (accessibility)
{%- endcomment -%}
<script>
  (function () {
    var section = document.getElementById('soleia-hero-{{ section.id }}');
    if (!section) return;
    var video = section.querySelector('.soleia-hero__video');
    if (!video) return;

    // Respect prefers-reduced-motion
    var mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (mq.matches) {
      video.pause();
    }
    mq.addEventListener('change', function (e) {
      e.matches ? video.pause() : video.play();
    });

    // Ensure autoplay on mobile (some browsers require explicit play() after user gesture)
    video.play().catch(function () {
      // Autoplay blocked — video stays on poster frame, that's fine
    });
  })();
</script>

{% schema %}
{
  "name": "Soleia Hero",
  "tag": "section",
  "class": "soleia-section",
  "settings": [
    {
      "type": "header",
      "content": "Background Video"
    },
    {
      "type": "video",
      "id": "video_shopify",
      "label": "Video — Shopify Hosted (recommended)",
      "info": "Upload an MP4 directly to Shopify. Best for performance and CDN delivery."
    },
    {
      "type": "text",
      "id": "video_url_mp4",
      "label": "Video URL — External MP4 (CDN fallback)",
      "info": "Use only if hosting externally. e.g. https://cdn.yoursite.com/hero.mp4"
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Poster / Fallback Image",
      "info": "Shown while the video loads and on devices that cannot autoplay video."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay Darkness",
      "default": 35
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image (overrides text logo below)"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (used if no image set)",
      "default": "soleia"
    },
    {
      "type": "text",
      "id": "nav_left",
      "label": "Left Nav Label",
      "default": "About"
    },
    {
      "type": "url",
      "id": "nav_left_url",
      "label": "Left Nav URL"
    },
    {
      "type": "text",
      "id": "nav_right",
      "label": "Right Nav Label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "nav_right_url",
      "label": "Right Nav URL"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "A new format for modern tea"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Plastic-free tea strips that dissolve in seconds. Pure flavour, functional botanicals, zero waste"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Join the Waitlist"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    }
  ],
  "presets": [
    {
      "name": "Soleia Hero"
    }
  ]
}
{% endschema %}
